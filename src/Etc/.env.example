# upMVC Environment Configuration
# Copy this file to .env and fill in your values.
# Keys marked REQUIRED must be set for the app to work correctly.

# -------------------------------------------------------
# Application
# -------------------------------------------------------
APP_NAME="upMVC Application"
APP_ENV=development          # development | production | testing
APP_DEBUG=true               # false in production
APP_KEY=                     # REQUIRED: php -r "echo bin2hex(random_bytes(32));"
APP_TIMEZONE=UTC             # e.g. Europe/Bucharest
APP_LOCALE=en

# -------------------------------------------------------
# Domain  (REQUIRED)
# -------------------------------------------------------
DOMAIN_NAME=http://localhost
# SITE_PATH: subfolder path if app is not at domain root
#   Apache subfolder : SITE_PATH=/upMVC/public
#   Domain root      : SITE_PATH=
#   PHP built-in     : SITE_PATH=
SITE_PATH=/upMVC/public

# -------------------------------------------------------
# Database  (REQUIRED)
# -------------------------------------------------------
DB_CONNECTION=mysql
DB_HOST=localhost
DB_PORT=3306
DB_NAME=your_database
DB_USER=root
DB_PASS=
DB_CHARSET=utf8mb4

# -------------------------------------------------------
# Cache
# -------------------------------------------------------
CACHE_DRIVER=file
CACHE_TTL=3600

# -------------------------------------------------------
# Session
# -------------------------------------------------------
SESSION_DRIVER=file
SESSION_LIFETIME=3600        # seconds
SESSION_EXPIRE_ON_CLOSE=false
SESSION_ENCRYPT=false
SESSION_COOKIE=upmvc_session
SESSION_DOMAIN=
SESSION_SECURE=false         # true if HTTPS
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax        # lax | strict | none

# -------------------------------------------------------
# Security
# -------------------------------------------------------
CSRF_PROTECTION=true
RATE_LIMIT=100               # general rate limit — requests per hour per IP

# Per-endpoint rate limits (max attempts / window in seconds)
RATE_LIMIT_LOGIN_MAX=10
RATE_LIMIT_LOGIN_WINDOW=900      # 15 minutes
RATE_LIMIT_SIGNUP_MAX=5
RATE_LIMIT_SIGNUP_WINDOW=3600    # 1 hour
RATE_LIMIT_REGISTER_MAX=5
RATE_LIMIT_REGISTER_WINDOW=3600  # 1 hour
RATE_LIMIT_API_MAX=100
RATE_LIMIT_API_WINDOW=60         # 1 minute

# -------------------------------------------------------
# CORS
# -------------------------------------------------------
CORS_ENABLED=false
CORS_ALLOWED_ORIGINS=*
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Content-Type,Authorization

# -------------------------------------------------------
# JWT  (REQUIRED if using JWT auth)
# -------------------------------------------------------
JWT_SECRET=                  # REQUIRED: php -r "echo bin2hex(random_bytes(32));"
JWT_ACCESS_TTL=3600          # access token lifetime in seconds  (1 hour)
JWT_REFRESH_TTL=2592000      # refresh token lifetime in seconds (30 days)

# -------------------------------------------------------
# Mail
# -------------------------------------------------------
MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_ENCRYPTION=tls
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=noreply@example.com
MAIL_FROM_NAME="${APP_NAME}"

# -------------------------------------------------------
# Logging
# -------------------------------------------------------
LOG_CHANNEL=file
LOG_LEVEL=debug              # debug | info | warning | error
LOG_PATH=src/logs            # relative to app root or absolute path

# -------------------------------------------------------
# Module Discovery (InitModsImproved)
# -------------------------------------------------------
ROUTE_ERROR_HANDLING=true       # show errors when a module fails to load
ROUTE_VERBOSE_LOGGING=true      # log successful route registrations
ROUTE_DEBUG_OUTPUT=false        # output raw discovery debug info (dev only)
ROUTE_SUBMODULE_DISCOVERY=true  # scan Modules/*/Modules/* nested structure
ROUTE_USE_CACHE=false           # cache discovered routes (true in production)

# -------------------------------------------------------
# Protected Routes
# -------------------------------------------------------
# Comma-separated route prefixes that require authentication.
# Overrides the defaults defined in Start.php.
# Example: PROTECTED_ROUTES=/admin/*,/dashboard/*,/account/*
PROTECTED_ROUTES=
